# ─── DFS - Variables de entorno configurables ─────────────────────────────────
#
# Copia este archivo como .env y ajusta los valores según tu entorno.
# Docker Compose carga automáticamente el archivo .env de la raíz del proyecto.
#
# Para usarlo:  cp .env.example .env

# ── NameNode ──────────────────────────────────────────────────────────────────

# Puerto expuesto al host para el NameNode
NAMENODE_PORT=8000

# Tamaño de bloque en bytes (default: 64 MB = 67108864)
BLOCK_SIZE=67108864

# Tiempo en segundos sin heartbeat para marcar un DataNode como caído
HEARTBEAT_TIMEOUT=90

# Número de copias de cada bloque (primario + réplicas)
REPLICATION_FACTOR=2

# ── DataNodes ─────────────────────────────────────────────────────────────────

# Intervalo en segundos entre heartbeats de los DataNodes
HEARTBEAT_INTERVAL=30
